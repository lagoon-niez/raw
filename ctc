/* STATE */
let ST=true,tried=new Set(),lastClickedSeat=null,lastActivity=Date.now();
let seatClicks=0,availableSeats=[],seatIndex=0;
let alertAudio=null;

const TOAST_TEXT="unavailable";
let handlingError=false;

/* DASHBOARD */
const DB=document.createElement("div");
DB.style.cssText=`
 position:fixed;
 top:70px;
