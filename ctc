/* UTILS */
const RD=(a,b)=>Math.floor(Math.random()*(b-a+1))+a;
const NL=t=>t.replace(/\s+/g," ").trim();
const kick=()=>lastActivity=Date.now();

function SN(s){ return Number(s.label.match(/\d+/)?.[0]||0); }

function isLowerSeat(label){
 const t=NL(label).toUpperCase();
 return /\bLL\b|\bRL\b|\bL\b/.test(t);
}

function RD_FAST(minFast,maxFast,minNormal,maxNormal){
 return SEAT_COUNT>=3
  ? Math.floor(Math.random()*(maxFast-minFast+1))+minFast
  : Math.floor(Math.random()*(maxNormal-minNormal+1))+minNormal;
}

