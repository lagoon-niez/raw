/* OBSERVER */
const observer=new MutationObserver(muts=>{
  if(!ST || onPay()) return;
 for(const m of muts){
  for(const n of m.addedNodes){
   if(n.nodeType!==1)continue;

   const text=(n.innerText||"").toLowerCase();

   if(text.includes(TOAST_TEXT)){
    onSeatUnavailable();
    return;
   }

   if(
    text.includes("seat selection incomplete") ||
    text.includes("please select seats for all passengers")
   ){
    if(!reloadTimer){
     scheduleReload(RD(3000,5000),"INCOMPLETE");
    }
    return;
   }
  }
 }
});

(observer.observe(document.getElementById("_rht_toaster")||document.body,{childList:true,subtree:true}));

/* SHIP SELECT */
function SSAS(){
 const shipQuery=SHIP.toLowerCase().trim(),
       seatQuery=SEAT.toLowerCase().trim();

 let attempts=0;

 const trySelect=()=>{
  try{
   const cards=document.querySelectorAll(".rounded-xl.border.bg-white");

   for(const card of cards){
    const shipEl=card.querySelector(".text-sm.text-gray-600 .font-semibold");
    if(!shipEl)continue;

    if(!shipEl.textContent.toLowerCase().includes(shipQuery))continue;

    const seatCards=card.querySelectorAll("a.rounded-xl.border");

    for(const seatCard of seatCards){
     const seatEl=seatCard.querySelector(".font-semibold");

     if(seatEl && seatEl.textContent.toLowerCase().includes(seatQuery)){
      seatCard.click();
      return;
     }
    }
   }

   if(++attempts<300)setTimeout(trySelect,250);

  }catch{
   if(++attempts<300)setTimeout(trySelect,250);
  }
 };

 setTimeout(trySelect,250);
}

/* PASSENGERS */
function detectPassengerPage(){
  if(!ST || onPay()) return;
 if(document.querySelector('button[role="checkbox"]')){
  selectPassengers();
  return;
 }
 setTimeout(detectPassengerPage,250);
}

function getVisiblePassengers(){
 return [...document.querySelectorAll('button[role="checkbox"]')]
  .filter(btn=>btn.offsetParent!==null);
}

function waitForPassengers(callback){
 const existing=getVisiblePassengers();

 if(existing.length){
  callback(existing);
  return;
 }

 const observer=new MutationObserver(()=>{
  const passengers=getVisiblePassengers();
  if(passengers.length){
   observer.disconnect();
   callback(passengers);
  }
 });

 observer.observe(document.body,{childList:true,subtree:true});
}

function selectPassengers(){
 waitForPassengers(passengers=>{
  let i=0;
  if(!ST || onPay()) return;
  function selectNext(){
   if(i>=PASSENGER_REQ.length){
    waitConfirm();
    return;
   }

   const idx=PASSENGER_REQ[i]-1,
         btn=passengers[idx];

   if(btn && btn.getAttribute("aria-checked")!=="true"){
    btn.click();
   }

   i++;
   setTimeout(selectNext,RD(200,350));
  }

  function waitConfirm(){
   const chk=setInterval(()=>{
    const selected=[
      ...document.querySelectorAll('button[role="checkbox"][aria-checked="true"]')
    ].filter(el=>el.offsetParent!==null);

    if(selected.length>=PASSENGER_REQ.length){
     clearInterval(chk);
     document.querySelector('button[type="submit"]:not([disabled])')?.click();
    }
   },150);
  }

  selectNext();
 });
}

/* SEATS */
function seatElements(){
 return [...document.querySelectorAll("svg g")].map(g=>{
  const r=g.querySelector("rect");
  if(!r)return null;

  const id=`${r.x.baseVal.value}-${r.y.baseVal.value}`;

  return{
   g,id,
   label:NL(g.querySelector("text")?.textContent||""),
   fill:(r.getAttribute("fill")||"").toLowerCase(),
   pwd:!!g.querySelector('image[href*="disability"]')
  };
 }).filter(Boolean);
}

function waitForSeats(){
 if(!ST || onPay()) return;

 if(document.querySelector("svg g rect"))
  requestAnimationFrame(scanSeats);
 else
  setTimeout(waitForSeats,120);
}

function scanSeats(){
 if(!ST || onPay()) return;

 kick();

 let seats=seatElements().filter(s=>{
  if(s.fill!=="#fff")return false;
  if(IS_DISABILITY_SEAT && !s.pwd)return false;
  if(!IS_DISABILITY_SEAT && s.pwd)return false;
  if(seatskip.some(x=>s.label.includes(x)))return false;
  return true;
 });

 seats=seats.filter(s=>!tried.has(s.id));

 if(!seats.length){
  smartReload();
  return;
 }

 let lower=seats.filter(s=>isLowerSeat(s.label));

 let pool=(PREFER_LOWER_SEATS && lower.length>=SEAT_COUNT)
  ? lower
  : seats;

 const A=[],B=[];

 for(const s of pool){
  const n=SN(s);
  if(START_SEAT==null || n>=START_SEAT) A.push(s);
  else B.push(s);
 }

 A.sort((a,b)=>SN(a)-SN(b));
 B.sort((a,b)=>SN(b)-SN(a));

 availableSeats=[...A,...B];
 seatIndex=0;
 seatClicks=0;

 assignNextSeat();
}

function assignNextSeat(){
 if(!ST || onPay()) return;

 if(seatClicks>=SEAT_COUNT){
  setTimeout(()=>{
   document.querySelector("div > div.flex.flex-col > div > div > button:not([disabled])")?.click();
  },500);
  return;
 }

 const seat=availableSeats[seatIndex];
 if(!seat)return;

 seatIndex++;

 setTimeout(()=>clickSeat(seat),RD_FAST(60,120,180,280));
}

function clickSeat(seat){
 if(!ST)return;

 kick();

 tried.add(seat.id);
 lastClickedSeat=seat;
 seatClicks++;

 const rect=seat.g.querySelector("rect");

 ["mousedown","mouseup","click"].forEach(e=>
  rect.dispatchEvent(new MouseEvent(e,{bubbles:true}))
 );

 setTimeout(assignSeat,RD_FAST(70,130,180,280));
}

function getSeatPopup(){
 return window.innerWidth<768
  ? document.querySelector('div[role="dialog"]')
  : document.querySelector('div.hidden.md\\:block');
}

function assignSeat(){
 const popup=getSeatPopup();

 if(!popup){
  setTimeout(assignSeat,RD_FAST(30,60,100,150));
  return;
 }

 const nextPassenger=popup.querySelector(
  'input[type="checkbox"]:not(:disabled):not(:checked)'
 );

 if(!nextPassenger){
  setTimeout(assignNextSeat,120);
  return;
 }

 setTimeout(()=>{
  nextPassenger.click();

  if(seatClicks>=SEAT_COUNT){
   setTimeout(()=>{
    document.querySelector("div > div.flex.flex-col > div > div > button:not([disabled])")?.click();
   },500);
  }else{
   setTimeout(assignNextSeat,RD_FAST(50,100,180,260));
  }

 },RD_FAST(80,140,220,320));
}

/* RELOADS */
function smartReload(){
 if(!ST || reloadTimer) return;
 const delay=RD(5500,9500);
 scheduleReload(delay,"SMART");
}

