let countdownInterval=null;
let reloadTimer=null;
let reloadCountdown=0;
let reloadType=null;

function scheduleReload(ms,type){
 clearInterval(countdownInterval);
 clearTimeout(reloadTimer);

 reloadType=type;
 reloadCountdown=Math.floor(ms/1000);

 updateDashboard();

 countdownInterval=setInterval(()=>{
  if(!ST){
   DB.textContent="Paused";
   return;
  }

  reloadCountdown--;

  if(reloadCountdown<=0){
   DB.textContent=`${type} â†’ Refreshing...`;
   clearInterval(countdownInterval);
   return;
  }

  updateDashboard();

 },1000);

 reloadTimer=setTimeout(()=>{
  if(!ST)return;

  tried.clear();
  location.reload();

 },ms);
}

function updateDashboard(){
 DB.textContent=`${reloadType} reload in: ${reloadCountdown}s`;
}

function stopCountdown(){
 clearInterval(countdownInterval);
 clearTimeout(reloadTimer);
 reloadTimer=null;
 DB.textContent="Idle";
}

